/* liquidether.js — Corrected Vanilla JS Port */
(function (global) {
  function makePaletteTexture(stops) {
    let arr = (Array.isArray(stops) && stops.length > 0)
      ? (stops.length === 1 ? [stops[0], stops[0]] : stops)
      : ['#ffffff', '#ffffff'];
    const w = arr.length;
    const data = new Uint8Array(w * 4);
    for (let i = 0; i < w; i++) {
      const c = new THREE.Color(arr[i]);
      data[i * 4 + 0] = Math.round(c.r * 255);
      data[i * 4 + 1] = Math.round(c.g * 255);
      data[i * 4 + 2] = Math.round(c.b * 255);
      data[i * 4 + 3] = 255;
    }
    const tex = new THREE.DataTexture(data, w, 1, THREE.RGBAFormat);
    tex.magFilter = THREE.LinearFilter;
    tex.minFilter = THREE.LinearFilter;
    tex.generateMipmaps = false;
    tex.needsUpdate = true;
    return tex;
  }

  // Shader Sources
  const face_vert = `attribute vec3 position; varying vec2 uv; void main(){ uv = 0.5 + position.xy * 0.5; gl_Position = vec4(position, 1.0); }`;
  
  const advection_frag = `
    precision highp float;
    uniform sampler2D velocity;
    uniform float dt;
    uniform vec2 fboSize;
    varying vec2 uv;
    void main(){
      vec2 ratio = max(fboSize.x, fboSize.y) / fboSize;
      vec2 vel = texture2D(velocity, uv).xy;
      vec2 uv2 = uv - vel * dt * ratio;
      gl_FragColor = vec4(texture2D(velocity, uv2).xy, 0.0, 1.0);
    }`;

  const externalForce_frag = `
    precision highp float;
    uniform vec2 force;
    uniform vec2 center;
    uniform float scale;
    varying vec2 uv;
    void main(){
      float d = distance(uv, center * 0.5 + 0.5);
      float f = exp(-d * d / (scale * 0.0001));
      gl_FragColor = vec4(force * f, 0.0, 1.0);
    }`;

  const color_frag = `
    precision highp float;
    uniform sampler2D velocity;
    uniform sampler2D palette;
    varying vec2 uv;
    void main(){
      vec2 vel = texture2D(velocity, uv).xy;
      float len = clamp(length(vel) * 0.5, 0.0, 1.0);
      vec3 color = texture2D(palette, vec2(len, 0.5)).rgb;
      gl_FragColor = vec4(color, len);
    }`;

  function initLiquidEther(container, opts) {
    const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
    renderer.setPixelRatio(window.devicePixelRatio);
    const canvas = renderer.domElement;
    canvas.style.position = 'absolute';
    canvas.style.top = '0';
    canvas.style.left = '0';
    canvas.style.pointerEvents = 'none';
    container.appendChild(canvas);

    const mouse = { curr: new THREE.Vector2(), old: new THREE.Vector2(), diff: new THREE.Vector2() };
    
    container.addEventListener('mousemove', (e) => {
      const r = container.getBoundingClientRect();
      mouse.curr.set((e.clientX - r.left) / r.width * 2 - 1, -((e.clientY - r.top) / r.height * 2 - 1));
    });

    const w = container.clientWidth * opts.resolution;
    const h = container.clientHeight * opts.resolution;
    renderer.setSize(container.clientWidth, container.clientHeight);

    // FBOs
    const type = /(iPad|iPhone|iPod)/i.test(navigator.userAgent) ? THREE.HalfFloatType : THREE.FloatType;
    const fbo0 = new THREE.WebGLRenderTarget(w, h, { type });
    const fbo1 = new THREE.WebGLRenderTarget(w, h, { type });

    // Passes
    const scene = new THREE.Scene();
    const camera = new THREE.Camera();
    const mesh = new THREE.Mesh(new THREE.PlaneGeometry(2, 2));
    scene.add(mesh);

    const forceMat = new THREE.RawShaderMaterial({
      vertexShader: face_vert, fragmentShader: externalForce_frag,
      uniforms: { force: { value: mouse.diff }, center: { value: mouse.curr }, scale: { value: opts.cursorSize } },
      blending: THREE.AdditiveBlending
    });

    const colorMat = new THREE.RawShaderMaterial({
      vertexShader: face_vert, fragmentShader: color_frag,
      uniforms: { velocity: { value: null }, palette: { value: makePaletteTexture(opts.colors) } },
      transparent: true
    });

    function render() {
      mouse.diff.subVectors(mouse.curr, mouse.old).multiplyScalar(opts.mouseForce);
      mouse.old.copy(mouse.curr);

      // Force Pass
      mesh.material = forceMat;
      renderer.setRenderTarget(fbo0);
      renderer.render(scene, camera);

      // Advection/Output Pass
      mesh.material = colorMat;
      colorMat.uniforms.velocity.value = fbo0.texture;
      renderer.setRenderTarget(null);
      renderer.render(scene, camera);

      requestAnimationFrame(render);
    }
    render();
  }
  global.initLiquidEther = initLiquidEther;
})(window);